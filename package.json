{
  "name": "@egchq/egc",
  "version": "1.1.14",
  "description": "EGC is a local-first MCP runtime that gives every AI agent the same brain: persistent shared memory, security guardrails, and up to 90% token savings across 20 AI coding tools.",
  "author": "Felipe Marzochi <fmarzochi@gmail.com> (https://github.com/Fmarzochi)",
  "license": "Apache-2.0",
  "prettier": {
    "singleQuote": true,
    "trailingComma": "none",
    "semi": true,
    "tabWidth": 2,
    "printWidth": 200,
    "arrowParens": "avoid"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Fmarzochi/EGC.git"
  },
  "homepage": "https://github.com/Fmarzochi/EGC",
  "bugs": {
    "url": "https://github.com/Fmarzochi/EGC/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "scripts/egc.js",
  "bin": {
    "egc": "scripts/egc.js",
    "egc-install": "scripts/install-apply.js",
    "egc-memory": "mcp/servers/egc-memory/build/index.js",
    "egc-guardian": "mcp/servers/egc-guardian/build/index.js"
  },
  "scripts": {
    "preinstall": "node scripts/preinstall.js",
    "test": "node tests/run-all.js",
    "test:state-store": "node tests/lib/state-store.test.js",
    "test:hooks": "node tests/hooks/hooks.test.js",
    "lint": "eslint .",
    "lint:md": "markdownlint --config .github/.markdownlint.json \"agents/**/*.md\" \"skills/**/*.md\" \"commands/**/*.md\" \"rules/**/*.md\"",
    "build": "npm run build:opencode && npm run build:mcp",
    "doctor": "node scripts/doctor.js",
    "bootstrap": "node scripts/bootstrap-state-db.js",
    "build:opencode": "node scripts/build-opencode.js",
    "build:mcp": "cd mcp/servers/egc-guardian && npm ci --silent && npm run build && cd ../egc-memory && npm ci --silent && npm run build",
    "prompt": "node scripts/gemini.js",
    "prepack": "npm run build:opencode && npm run build:mcp"
  },
  "files": [
    "scripts/",
    "dashboard/",
    "src/",
    "agents/",
    "commands/",
    "hooks/",
    "skills/",
    "rules/",
    "schemas/",
    "manifests/",
    "mcp-configs/",
    "examples/",
    ".gemini-plugin/",
    ".codex-plugin/",
    ".opencode/",
    ".codebuddy/",
    ".kiro/",
    ".trae/",
    ".agents/",
    "mcp/servers/egc-guardian/build/",
    "mcp/servers/egc-guardian/package.json",
    "mcp/servers/egc-memory/build/",
    "mcp/servers/egc-memory/package.json",
    ".mcp.json",
    "agent.yaml",
    "VERSION",
    "README.md",
    "LICENSE",
    "NOTICE",
    ".github/CONTRIBUTING.md",
    "docs/RULES.md",
    ".github/SECURITY.md"
  ],
  "dependencies": {
    "ajv": "^8.12.0",
    "argparse": "^3.0.0",
    "js-yaml": "^4.2.0",
    "sql.js": "^1.14.1",
    "ws": "^8.16.0"
  },
  "keywords": [
    "egc",
    "extended-global-context",
    "mcp",
    "model-context-protocol",
    "mcp-server",
    "ai-agent",
    "agent-memory",
    "persistent-memory",
    "context-sharing",
    "token-optimizer",
    "claude-code",
    "cursor",
    "codex",
    "aider",
    "windsurf",
    "agent-orchestration",
    "local-first",
    "developer-tools",
    "hooks"
  ],
  "devDependencies": {
    "@continuedev/config-yaml": "^1.42.0",
    "@eslint/js": "^10.0.1",
    "@iarna/toml": "^2.2.5",
    "@jazzer.js/core": "4.0.0",
    "@types/node": "^26.0.0",
    "eslint": "^10.0.0",
    "globals": "^17.6.0",
    "markdownlint-cli": "^0.49.0"
  },
  "overrides": {
    "js-yaml": "^4.2.0",
    "markdown-it": "^14.2.0"
  },
  "pnpm": {
    "overrides": {
      "js-yaml": "^4.2.0",
      "markdownlint-cli>js-yaml": "^4.2.0",
      "markdown-it": "^14.2.0"
    }
  }
}
