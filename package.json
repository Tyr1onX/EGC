    "test:state-store": "node tests/lib/state-store.test.js",
    "test:hooks": "node tests/hooks/hooks.test.js",
    "doctor": "node scripts/doctor.js",
    "bootstrap": "node scripts/bootstrap-state-db.js",
    "build:opencode": "node scripts/build-opencode.js",
    "prompt": "node scripts/gemini.js",
    "prepack": "npm run build:opencode"
  },
  "files": [
    "scripts/",
    "src/",
    "agents/",
    "commands/",
    "hooks/",
    "skills/",
    "rules/",
    "schemas/",
    "manifests/",
    "internal/",
    "plugins/",
    "mcp-configs/",
    "legacy-command-shims/",
    "examples/",
    ".gemini-plugin/",
    ".codex-plugin/",
    ".opencode/",
    ".codebuddy/",
    ".kiro/",
    ".trae/",
    ".agents/",
    ".mcp.json",
    "agent.yaml",
    "VERSION",
    "bootstrap.py",
    "startup.py",
    "egc.py",
    "egc_dashboard.py",
    "install.sh",
    "install.ps1",
    "run.sh",
    "run.ps1",
    "pyproject.toml",
    "requirements.txt",
    "README.md",
    "LICENSE",
    "CONTRIBUTING.md",
    "RULES.md",
    "SECURITY.md"
  ],
  "dependencies": {
    "ajv": "^8.12.0",
    "argparse": "^2.0.1",
    "better-sqlite3": "^12.10.0",
    "js-yaml": "^4.1.1"
  },
  "keywords": [
    "egc",
    "everything-gemini",
    "ai",
    "coding",
    "agent",
    "gemini",
    "claude",
    "openai",
    "hooks",
    "orchestration"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@iarna/toml": "^2.2.5",
    "@types/node": "^20.0.0",
    "globals": "^17.6.0",
    "markdownlint-cli": "^0.48.0",
    "typescript": "^5.3.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
