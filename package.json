{
  "name": "everything-gemini",
  "version": "1.0.0",
  "description": "EGC \u2014 Everything Gemini Code. Multi-harness AI coding plugin ecosystem.",
  "author": "Felipe Marzochi <fmarzochi@gmail.com> (https://github.com/Fmarzochi)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Fmarzochi/everything-gemini.git"
  },
  "homepage": "https://github.com/Fmarzochi/everything-gemini",
  "bugs": {
    "url": "https://github.com/Fmarzochi/everything-gemini/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "scripts/egc.js",
  "bin": {
    "egc": "scripts/egc.js",
    "egc-install": "scripts/install-apply.js"
  },
  "scripts": {
